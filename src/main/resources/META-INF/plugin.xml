<!-- 插件配置文件。更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- 插件的唯一标识符。应该是完全限定名。在插件版本之间不能更改。 -->
    <id>dev.dong4j.idea.skill.inspector</id>

    <!-- 公共插件名称应使用标题大小写书写。
         指南：https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Skill Inspector</name>

    <!-- 在插件页面上显示的供应商名称或组织ID。 -->
    <vendor email="dong4j@gmail.com">dong4j</vendor>

    <!-- 产品和插件兼容性要求。
         更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>org.intellij.plugins.markdown</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <!-- 国际化资源文件 -->
    <resource-bundle>messages.SkillInspectorBundle</resource-bundle>

    <!-- 插件定义的扩展点。
         更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- 应用级设置服务 -->
        <applicationService serviceImplementation="dev.dong4j.idea.skill.inspector.settings.SkillInspectorSettings"/>

        <!-- Settings | Tools | Skill Inspector -->
        <applicationConfigurable parentId="tools"
                                 instance="dev.dong4j.idea.skill.inspector.settings.SkillInspectorConfigurable"
                                 displayName="Skill Inspector"/>

        <!-- 状态栏问题计数：id 必须与 SkillInspectorStatusBarWidgetFactory.getId() 一致，
             否则 verifyPluginStructure 会报错 -->
        <statusBarWidgetFactory id="SkillInspectorStatusBar"
                                implementation="dev.dong4j.idea.skill.inspector.statusbar.SkillInspectorStatusBarWidgetFactory"/>

        <!-- 通知组 -->
        <!--suppress PluginXmlI18n -->
        <notificationGroup id="Skill Inspector Notifications"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

        <!-- SKILL.md 规范检查
             绑定 Markdown 以满足 IntelliJ plugin.xml schema, 真实边界仍由
             SkillFileDetector 和 SkillMdInspection 的幂等保护共同收束。 -->
        <localInspection language="Markdown"
                         groupBundle="messages.SkillInspectorBundle"
                         groupKey="inspection.group.name"
                         shortName="SkillMdInspection"
                         bundle="messages.SkillInspectorBundle"
                         key="inspection.skill.md.display.name"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.dong4j.idea.skill.inspector.inspection.SkillMdInspection"/>
    </extensions>

    <!-- 插件定义的动作 -->
    <actions>
        <!-- 编辑器右键菜单: 校验"项目里全部 SKILL.md", 适合批量验证 -->
        <action id="dev.dong4j.idea.skill.inspector.action.SkillInspectorAction"
                class="dev.dong4j.idea.skill.inspector.action.SkillInspectorAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <!-- 编辑器右下角浮动按钮使用: 只校验"DataContext 里的当前文件", 不扫全项目.
             不挂任何菜单组, 仅供 floating/SkillBottomFloatingButton 通过 ActionManager 取出后调用. -->
        <action id="dev.dong4j.idea.skill.inspector.action.ValidateCurrentSkillFileAction"
                class="dev.dong4j.idea.skill.inspector.action.ValidateCurrentSkillFileAction"/>
    </actions>

    <!-- 编辑器右下角自定义浮动按钮 (毛玻璃 FAB):
         AppLifecycleListener 在 IDE 主窗口创建后挂载全局 EditorFactoryListener,
         为每个 SKILL.md 主编辑器在 RootPane.layeredPane 上注入按钮.
         实现见 floating/SkillBottomFloatingInstaller + SkillBottomFloatingButton. -->
    <applicationListeners>
        <listener class="dev.dong4j.idea.skill.inspector.floating.SkillBottomFloatingInstaller"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>
</idea-plugin>
